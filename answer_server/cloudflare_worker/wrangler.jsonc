{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pve-answer-worker",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-05",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "GITHUB_RAW_BASE_URL": "https://raw.githubusercontent.com/buddy9880/pve-unattended-install/refactor-cloudflare-answer-server"
  }
}
